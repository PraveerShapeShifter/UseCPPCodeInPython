{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests", "-q"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: Flask example",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/examples/flask_api.py",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "C++: attach to running python.exe",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
